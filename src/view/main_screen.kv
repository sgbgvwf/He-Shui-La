#:kivy 2.2
#:import Companion3DWidget src.view.widgets.companion_3d.Companion3DWidget
#:import ProgressStars src.view.widgets.progress_stars.ProgressStars
#:import StreakFire src.view.widgets.streak_fire.StreakFire
#:import SettingsGear src.view.widgets.settings_gear.SettingsGear
#:import StickerIcon src.view.widgets.sticker_icon.StickerIcon
#:import Toast src.view.widgets.toast.Toast
# 喝水啦 — 主界面布局

<MainScreen>:
    orientation: "vertical"
    padding: 30
    spacing: 20
    canvas.before:
        Color:
            rgba: 0.95, 0.95, 1.0, 1
        Rectangle:
            pos: self.pos
            size: self.size

    # ── 顶栏: 形态 + 图标 ──
    BoxLayout:
        size_hint_y: 0.10
        orientation: "horizontal"

        Label:
            font_name: "ChineseHei"
            text: companion_3d.current_name
            font_size: "28sp"
            bold: True
            color: 0.2, 0.5, 0.9, 1

        BoxLayout:
            orientation: "horizontal"
            size_hint_x: None
            width: "88sp"
            spacing: "6sp"

            StickerIcon:
                size_hint_x: 1
                callback: root.open_achievements

            SettingsGear:
                size_hint_x: 1
                callback: root.open_settings

    # ── 3D 伙伴模型 ──
    Companion3DWidget:
        id: companion_3d
        viewmodel: root.vm
        size_hint_y: 0.40

    # ── 连续天数火焰 ──
    StreakFire:
        id: streak_fire
        viewmodel: root.vm
        size_hint_y: 0.06

    # ── 喝水统计 ──
    Label:
        font_name: "ChineseHei"
        text: "Lv." + str(companion_3d.current_level) + "  已喝 " + str(root.vm.today_cups) + " 杯"
        font_size: "18sp"
        color: 0.3, 0.3, 0.3, 1
        size_hint_y: 0.05

    # ── 今日进度星星 ──
    ProgressStars:
        id: progress_stars
        viewmodel: root.vm
        size_hint_y: 0.05

    # ── Toast 提示 ──
    Toast:
        font_name: "ChineseHei"
        text: root.vm.toast_message
        visible: root.vm.toast_visible
        font_size: "18sp"
        color: 1.0, 0.4, 0.3, 1
        size_hint_y: 0.06

    # ── 喝水按钮 ──
    Button:
        font_name: "ChineseHei"
        text: root.vm.button_text
        font_size: "36sp"
        bold: True
        size_hint_y: 0.28
        background_normal: ""
        background_color: (0.3, 0.6, 1.0, 1) if not root.vm.button_disabled else (0.7, 0.7, 0.7, 1)
        color: 1, 1, 1, 1
        disabled: root.vm.button_disabled
        opacity: 0.6 if root.vm.button_disabled else 1.0
        on_release: root.vm.drink_water()
        canvas.before:
            Color:
                rgba: self.background_color
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [40]
